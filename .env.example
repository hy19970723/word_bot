# DeepSeek LLM配置
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== 可灵视频生成配置 =====
# 安装: npm i -g @klingai/cli-cn
# 登录: kling login
KLING_CLI_COMMAND=kling

# 视频模型 (越新越贵)
# kling-video-v2_5      最便宜，速度快
# kling-video-v2_6      中等
# kling-video-v3_0_turbo  性价比高
# kling-video-v3_0      最新最好
KLING_MODEL=kling-video-v2_5

# 视频分辨率
# 720p   标准画质（省一半）
# 1080p  高清画质
KLING_RESOLUTION=720p

# 视频时长(秒)
# 5   短片段（省一半）
# 10  长片段
KLING_DURATION=5

# 生成模式
# all_video  全部用AI视频（最贵，效果最好）
# mixed      开头/结尾用视频，中间用图片（平衡）
# all_image  全部用AI图片（最省，配合MoviePy做Ken Burns效果）
KLING_VIDEO_MODE=all_video

# 图片模型 (mixed/all_image模式使用)
# kling-image-v2_1    最便宜
# kling-image-v3_0    最新最好
KLING_IMAGE_MODEL=kling-image-v2_1

# 图片分辨率 (mixed/all_image模式使用)
# 1k   标准（最省）
# 2k   高清
# 4k   超高清
KLING_IMAGE_RESOLUTION=1k

# ===== LLM模型配置 =====
# 编剧模型
# auto       按内容类型自动选（science/story用reasoner，trending/product用chat）
# chat       全部用deepseek-chat（快、省，约0.04 CNY/次）← 默认
# reasoner   全部用deepseek-reasoner（深度思考，约0.16 CNY/次）
LLM_SCREENWRITER_TIER=chat

# 是否启用审核Agent
# true   启用（多一轮LLM调用，约0.03 CNY）
# false  关闭（省一轮LLM，直接跳到人工审核成片）
LLM_REVIEWER_ENABLED=true

# 审核模型
# efficient   用deepseek-chat（快省）
# reasoning   用deepseek-reasoner（深度评估）
LLM_REVIEWER_TIER=efficient

# ===== 预览模式 =====
# true   只生成第1个镜头（快速预览效果，省75%可灵费用）
# false  生成全部镜头
PREVIEW_MODE=false

# ===== 镜头与预算 =====
# 最大镜头数（镜头越少越省）
MAX_SHOTS=4

# 预算控制
MAX_TOKENS_PER_VIDEO=8000
MAX_IMAGES_PER_VIDEO=8
MAX_RETRY_ROUNDS=2
COST_LIMIT_PER_VIDEO=5.0

# ===== 输出配置 =====
OUTPUT_DIR=./output
PROJECTS_DIR=./projects
LOG_LEVEL=INFO
DEFAULT_RESOLUTION=1080x1920
DEFAULT_FPS=30
DEFAULT_ASPECT_RATIO=9:16
